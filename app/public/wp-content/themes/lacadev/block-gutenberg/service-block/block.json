{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lacadev/service-block",
  "title": "Layout: Icon Cards",
  "description": "Hiển thị danh sách nội dung dạng card + ký tự icon (chọn được Post Type + taxonomy)",
  "category": "lacadev-blocks",
  "icon": "megaphone",
  "editorScript": "lacadev-block-service-block-editor",
  "editorStyle": "lacadev-block-service-block-editor",
  "style": "lacadev-block-service-block",
  "keywords": ["service", "laca"],
  "textdomain": "laca",
  "attributes": {
    "postType": {
      "type": "string",
      "default": "service"
    },
    "taxonomy": {
      "type": "string",
      "default": ""
    },
    "termIds": {
      "type": "array",
      "default": []
    },
    "mode": {
      "type": "string",
      "default": "manual"
    },
    "postIds": {
      "type": "array",
      "default": []
    },
    "title": {
      "type": "string",
      "default": "LA CÀ DEV CÓ GÌ"
    },
    "description": {
      "type": "string",
      "default": "<p>La cà Dev là nơi mình làm web WordPress, thiết kế thương hiệu và hỗ trợ marketing online.</p><p>Mình giúp bạn tạo ra một website chỉn chu, dễ dùng và có cá tính riêng – từ giao diện đến nội dung, tất cả đều hướng đến sự hiệu quả và phù hợp với bạn.</p>"
    },
    "serviceIds": {
      "type": "array",
      "default": []
    },
    "buttonText": {
      "type": "string",
      "default": "Cùng tôi tạo nên thương hiệu của bạn"
    },
    "buttonUrl": {
      "type": "string",
      "default": "/lien-he/"
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  }
}
